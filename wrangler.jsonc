{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "daviddong",
  "main": "src/worker/index.ts",
  "compatibility_date": "2025-12-08",
  "routes": [
    { "pattern": "daviddong.me", "custom_domain": true }
  ],
  "preview_urls": true,
  "workers_dev": true,
  "assets": {
    // Built frontend (vite build output).
    "directory": "./dist/client",
    // Exposes static assets to the Worker as env.ASSETS.
    "binding": "ASSETS",
    // Serve index.html for unknown client-side routes (SPA).
    "not_found_handling": "single-page-application",
    // Serve static files (HTML/JS/CSS/images) straight from the CDN without
    // invoking the Worker — those hits do NOT count against the Worker
    // request quota. The Worker only runs for non-asset paths (/api/*).
    "run_worker_first": false
  },
  "observability": {
    "enabled": true
  },
  "kv_namespaces": [
    // Saved chord sheets for Chords.app (see src/worker/index.ts /api/sheets).
    { "binding": "CHORD_SHEETS", "id": "86bd89398e6a4b4784a8b2d3c6c40d03" }
  ],
  "r2_buckets": [
    // HK photogrammetry tiles for CausewayBay.app (~90MB of GLBs, key prefix
    // hk-tiles/). Uploaded by scripts/hk-tiles/upload-r2.sh and served by the
    // /models/hk-tiles/* route in src/worker/index.ts — the folder is
    // gitignored, so production asset builds don't contain it and requests
    // fall through to the Worker.
    { "binding": "MODELS", "bucket_name": "daviddong-assets" }
  ]
  // Future backend bindings go here, e.g.:
  // "d1_databases": [
  //   { "binding": "DB", "database_name": "daviddong", "database_id": "..." }
  // ]
}
